+def _group_average_channel_procrustes_transform(transforms):
+    transforms = tuple(transforms)
+    if not transforms:
+        return None
+    rotations = np.stack([np.asarray(transform["rotation"], dtype=float) for transform in transforms], axis=0)
+    mean_rotation = np.mean(rotations, axis=0)
+    left, _singular_values, right_t = np.linalg.svd(mean_rotation, full_matrices=False)
+    rotation = left @ right_t
+    return {
+        "source_center": np.mean(np.stack([np.asarray(transform["source_center"], dtype=float) for transform in transforms], axis=0), axis=0),
+        "target_center": np.mean(np.stack([np.asarray(transform["target_center"], dtype=float) for transform in transforms], axis=0), axis=0),
+        "rotation": rotation,
+    }
